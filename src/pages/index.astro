---
import Game from '../layouts/Game.astro';
---

<Game title="苏打人生">
  <main class="flex flex-col items-center justify-center h-dvh gap-12">
    <div class="text-center">
      <h1 class="font-['Press_Start_2P'] text-2xl md:text-3xl text-[#16c79a] tracking-[0.5rem] mb-4" style="text-shadow: 0 0 20px rgba(22,199,154,0.5);">
        苏打人生
      </h1>
      <p class="text-[#8a8a9a] text-base md:text-lg tracking-[0.3rem]">人生一场大梦，叶落知多少？</p>
    </div>
    <div class="flex flex-col gap-4">
      <button id="start-btn" class="font-['Press_Start_2P'] text-xs md:text-sm border-2 border-[#16c79a] text-[#16c79a] px-8 py-4 md:px-12 tracking-[0.2rem] transition-all duration-200 cursor-pointer bg-transparent hover:bg-[#16c79a] hover:text-[#1a1a2e] hover:shadow-[0_0_20px_rgba(22,199,154,0.5)]">
        开始游戏
      </button>
    </div>
    <div class="fixed bottom-8 font-['Press_Start_2P'] text-[0.5rem] text-[#444]">DEMO v0.1</div>
  </main>
</Game>

<script>
  document.getElementById('start-btn')?.addEventListener('click', () => {
    window.location.href = '/play';
  });
</script>
